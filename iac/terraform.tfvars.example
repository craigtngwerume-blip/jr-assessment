# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git (it's in .gitignore)

region           = "af-south-1"
name             = "jr-assessment"
owner            = "craig"
instance_type    = "t3.micro"
root_volume_size = 10
my_ip            = "YOUR.PUBLIC.IP.HERE/32"   # e.g. "41.220.100.5/32"
bucket_name      = "jr-website-craig-7842"
