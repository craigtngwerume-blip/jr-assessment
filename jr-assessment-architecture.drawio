        <!-- setup_web.sh -->
        <mxCell id="55" value="📜 setup_web.sh&#xa;— idempotent, run manually —&#xa;&#xa;set -euo pipefail&#xa;exec &gt; tee setup_web.log&#xa;rpm -q httpd || yum install&#xa;systemctl enable --now httpd&#xa;Writes 'Ola World' index.html&#xa;Exits non-zero on failure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8d5ff;strokeColor=#9c27b0;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
